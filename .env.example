# Copy this file to .env and fill in your key.
# This project calls models through OpenRouter (https://openrouter.ai), so one key
# gives you access to Claude, Gemini, GPT, etc. Get a key at:
#   https://openrouter.ai/keys   (it starts with sk-or-v1-...)
OPENROUTER_API_KEY=sk-or-...

# Any OpenRouter model id. Cheap + fast is perfect for per-review extraction.
EXTRACT_MODEL=anthropic/claude-haiku-4.5
# A stronger model for the weekly synthesis report.
REPORT_MODEL=anthropic/claude-sonnet-4.5

# Cheaper alternatives you can swap in for EXTRACT_MODEL to save credits:
#   openai/gpt-5-nano          (extremely cheap)
#   google/gemini-flash-latest
#   anthropic/claude-3-haiku
