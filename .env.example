# Copy this file to .env and fill in your key.
# Get one at https://console.anthropic.com/  → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Model to use. Cheap + fast is perfect for per-review extraction.
EXTRACT_MODEL=claude-haiku-4-5-20251001
# A stronger model for the weekly synthesis report.
REPORT_MODEL=claude-sonnet-5
